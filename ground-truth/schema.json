{
  "description": "Ground truth schema — defines expected answer fields per category with match strategies. Used by gt_evaluator.py to score search results against verified facts.",
  "match_strategies": {
    "name_in_text": "Case-insensitive substring match. Full name → exact match (1.0). Last name only → partial (0.5). Levenshtein distance <= 2 → fuzzy (0.8).",
    "names_in_text": "Count how many expected names appear in snippets. Score = found / expected. Minimum 1 match for non-zero score.",
    "field_present": "Check if data type exists in snippets. Money pattern ($X, raised X), date pattern, URL pattern, etc.",
    "text_match": "Check if expected text or close semantic equivalent appears. Exact match = 1.0, substring = 0.8.",
    "list_overlap": "Count overlap between expected list and found items. Score = intersection / expected.",
    "boolean_present": "Check if the expected signal exists at all. 1.0 if found, 0.0 if not."
  },
  "categories": {
    "company_profile": {
      "fields": {
        "description": {
          "type": "text",
          "required": true,
          "description": "What the company does (one sentence)"
        },
        "employee_count": {
          "type": "text",
          "required": false,
          "description": "Employee count or range"
        },
        "headquarters": {
          "type": "text",
          "required": false,
          "description": "HQ city/location"
        },
        "founded_year": {
          "type": "text",
          "required": false,
          "description": "Year founded"
        }
      },
      "match_strategy": "field_present",
      "description": "Basic company overview data"
    },
    "funding_financial": {
      "fields": {
        "total_raised": {
          "type": "money",
          "required": true,
          "description": "Total funding raised"
        },
        "last_round_type": {
          "type": "text",
          "required": false,
          "description": "Most recent round type (Seed, Series A, etc.)"
        },
        "key_investors": {
          "type": "name_list",
          "min": 1,
          "required": false,
          "description": "Notable investors"
        }
      },
      "match_strategy": "field_present",
      "description": "Funding rounds and financial data"
    },
    "hiring_signals": {
      "fields": {
        "ats_platform": {
          "type": "text",
          "required": false,
          "description": "ATS used (Greenhouse, Lever, Ashby, etc.)"
        },
        "careers_url": {
          "type": "text",
          "required": false,
          "description": "Careers page URL or indicator"
        },
        "active_hiring": {
          "type": "boolean",
          "required": true,
          "description": "Whether company is actively hiring"
        }
      },
      "match_strategy": "boolean_present",
      "description": "Hiring activity and job posting signals"
    },
    "competitor_identification": {
      "fields": {
        "competitors": {
          "type": "name_list",
          "min": 3,
          "required": true,
          "description": "Direct competitors"
